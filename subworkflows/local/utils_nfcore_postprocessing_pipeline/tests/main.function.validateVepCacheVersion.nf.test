nextflow_function {

    name "Test Subworkflow UTILS_NFCORE_POSTPROCESSING_PIPELINE validateVepCacheVersion function"
    script "subworkflows/local/utils_nfcore_postprocessing_pipeline/main.nf"
    tag "local"

    function "validateVepCacheVersion"

    test("Test Function validateVepCacheVersion succeeds when cache version matches VEP container") {
        when {
            params {
                vep_cache_version = "111"
                download_cache    = false
            }
            function {
                """
                """
            }
            then {
                assertAll(
                    { assert function.success }
                )
            }
        }
    }

    test("Test Function validateVepCacheVersion fails when cache version does not match VEP container") {
        when {
            params {
                vep_cache_version = "999"
                download_cache    = false
            }
            function {
                """
                """
            }
            then {
                assertAll(
                    { assert function.failed }
                )
            }
        }
    }

    test("Test Function validateVepCacheVersion succeeds when cache version matches both VEP and download containers") {
        when {
            params {
                vep_cache_version = "111"
                download_cache    = true
            }
            function {
                """
                """
            }
            then {
                assertAll(
                    { assert function.success }
                )
            }
        }
    }

    test("Test Function validateVepCacheVersion fails with download_cache when cache version does not match containers") {
        when {
            params {
                vep_cache_version = "999"
                download_cache    = true
            }
            function {
                """
                """
            }
            then {
                assertAll(
                    { assert function.failed }
                )
            }
        }
    }
}
