/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Slivar inheritance / segregation expressions
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-process options for the SLIVAR_INHERITANCE subworkflow:
      - SLIVAR_EXPR          : runs `slivar expr` with the moi_*(fam) tag functions
                               from assets/slivar-functions.js. The list below is
                               just `tag : moi_function(fam) <AF clause>` -- the
                               actual logic lives in the JS file.
      - SLIVAR_COMPOUNDHETS  : pairs comphet_side / het_side / denovo variants
                               within genes.
      - BCFTOOLS_ANNOTATE    : folds the compound-hets annotation onto the
                               expr output and strips the intermediate side fields.

    Loaded from nextflow.config after conf/modules.config so the slivar process
    options replace any earlier defaults.
----------------------------------------------------------------------------------------
*/

process {

    withName: SLIVAR_EXPR {
        publishDir = [
            path: { "${params.outdir}/slivar" },
            pattern: '*.slivar.summary.txt',
            mode: params.publish_dir_mode,
        ]
        ext.prefix = { "variants.${meta.id}.snv.vep.expr" }

        // Local `def` declarations must sit inside a closure scope (the Nextflow
        // language server rejects them at the withName level), so the whole
        // expression list is built lazily inside the ext.args closure.
        ext.args = {
            // AF-threshold clauses built from Nextflow params (empty when the
            // param is unset, so the appended clause is a no-op).
            def afRare      = params.slivar_gnomad_gnotate && params.gnomad_popmax_af_rare      ? "&& INFO.gnomad_popmax_af < ${params.gnomad_popmax_af_rare}"      : ''
            def afTopmed    = params.slivar_topmed_gnotate && params.topmed_af_rare             ? "&& INFO.topmed_af < ${params.topmed_af_rare}"                    : ''
            def afDominant  = params.slivar_gnomad_gnotate && params.gnomad_popmax_af_dominant  ? "&& INFO.gnomad_popmax_af < ${params.gnomad_popmax_af_dominant}"  : ''
            def afRecessive = params.slivar_gnomad_gnotate && params.gnomad_popmax_af_recessive ? "&& INFO.gnomad_popmax_af < ${params.gnomad_popmax_af_recessive}" : ''
            def afNhomalt   = params.slivar_gnomad_gnotate && params.gnomad_nhomalt             ? "&& INFO.gnomad_nhomalt < ${params.gnomad_nhomalt}"               : ''

            // Each row maps a tag name to a moi_*(fam) function defined in
            // assets/slivar-functions.js. The AF clause is the only runtime
            // variable; the actual MoI logic lives in the JS file.
            [
                // Pre-filter applied to every variant before any --family-expr is evaluated.
                "--info 'variant.FILTER == \"PASS\" && variant.ALT[0] != \"*\" && INFO.impactful ${afRare} ${afTopmed}'",

                // Autosomal MoIs. denovo self-gates to trios via segregating_denovo;
                // dominant requires an affected parent (else it would fire on de novos);
                // upd requires a complete trio with exactly one parent hom_ref.
                "--family-expr 'denovo:moi_denovo(fam) ${afDominant}'",
                "--family-expr 'recessive:moi_recessive(fam) ${afRecessive}'",
                "--family-expr 'dominant:moi_dominant(fam) ${afDominant}'",
                "--family-expr 'uniparental_disomy:moi_upd(fam) ${afRecessive}'",

                // X-linked MoIs.
                "--family-expr 'x_denovo:moi_x_denovo(fam) ${afDominant}'",
                "--family-expr 'x_recessive:moi_x_recessive(fam) ${afRecessive}'",
                "--family-expr 'x_dominant:moi_x_dominant(fam) ${afDominant}'",

                // Compound-het sides:
                //   trios:     transmission-aware comphet_side(kid, mom, dad) via --trio
                //   non-trios: moi_het_side(fam) -- any hq het in an affected member,
                //              dropped if any unaffected parent is hom_alt
                "--trio 'comphet_side:comphet_side(kid, mom, dad) ${afNhomalt}'",
                "--family-expr 'het_side:moi_het_side(fam) ${afNhomalt}'",

                // Set alongside an MoI tag when family structure can't prove segregation
                // (recessive in non-trio, x_recessive without informative structure,
                // any non-trio comphet pairing). Downstream lower-confidence flag.
                "--family-expr 'candidate:moi_candidate(fam)'",
            ].join(" ")
        }
    }

    withName: SLIVAR_COMPOUNDHETS {
        publishDir = [
            path: { "${params.outdir}/slivar" },
            pattern: '*.slivar.summary.txt',
            mode: params.publish_dir_mode,
        ]

        // sample-fields consumed here:
        //   comphet_side  -- populated by `--trio comphet_side` for trios (transmission-aware)
        //   het_side      -- populated by the duo/solo family-expr above (any hq het in proband)
        //   denovo        -- so a de novo variant can pair with an inherited het in the same gene
        ext.args = { "--allow-non-trios --sample-field comphet_side --sample-field denovo --sample-field het_side" }
        ext.prefix = { "variants.${meta.id}.snv.vep.ch" }
    }

    withName: BCFTOOLS_ANNOTATE {
        ext.args = { "-Oz -c INFO/slivar_comphet -x INFO/comphet_side,INFO/het_side --write-index=tbi" }
        ext.prefix = { "variants.${meta.id}.snv.vep.slivar" }
        publishDir = [
            path: { "${params.outdir}/slivar" },
            publish_mode: params.publish_dir_mode,
            pattern: '*{vcf.gz,vcf.gz.tbi}'
        ]
    }
}
