nextflow_function {

    name "Test Subworkflow UTILS_NFCORE_POSTPROCESSING_PIPELINE validatePedFiles function"
    script "subworkflows/local/utils_nfcore_postprocessing_pipeline/main.nf"
    tag "local"

    function "validatePedFiles"

    test("Test Function validatePedFiles with familyPed meta missing for all family members") {
        when {
            function {
                //The validation should succeed
                """
                input[0] = "family2"
                input[1] = [
                    [[sample:"NA07019", familyId:"family2", sequencingType:"WES"], "data-test/gvcf/NA07019.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07022", familyId:"family2", sequencingType:"WES"], "data-test/gvcf/NA07022.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07056", familyId:"family2", sequencingType:"WES"], "data-test/gvcf/NA07056.chr22_50000000-51000000.g.vcf.gz"]
                ]
                """
            }
            then {
                assertAll(
                    { assert function.success }
                )
            }
        }
    }

    test("Test Function validatePedFiles with familyPed meta empty for all family members") {
        when {
            function {
                //The validation should succeed (empty values are filtered out)
                """
                input[0] = "family2"
                input[1] = [
                    [[sample:"NA07019", familyId:"family2", sequencingType:"WES", familyPed: ""], "data-test/gvcf/NA07019.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07022", familyId:"family2", sequencingType:"WES", familyPed: ""], "data-test/gvcf/NA07022.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07056", familyId:"family2", sequencingType:"WES", familyPed: ""], "data-test/gvcf/NA07056.chr22_50000000-51000000.g.vcf.gz"]
                ]
                """
            }
            then {
                assertAll(
                    { assert function.success }
                )
            }
        }
    }

    test("Test Function validatePedFiles with familyPed meta specified and identical for all family members") {
        when {
            function {
                //The validation should succeed
                """
                input[0] = "family2"
                input[1] = [
                    [[sample:"NA07019", familyId:"family2", sequencingType:"WES", familyPed: "data-test/ped/family2.ped"], "data-test/gvcf/NA07019.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07022", familyId:"family2", sequencingType:"WES", familyPed: "data-test/ped/family2.ped"], "data-test/gvcf/NA07022.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07056", familyId:"family2", sequencingType:"WES", familyPed: "data-test/ped/family2.ped"], "data-test/gvcf/NA07056.chr22_50000000-51000000.g.vcf.gz"]
                ]
                """
            }
            then {
                assertAll(
                    { assert function.success }
                )
            }
        }
    }

    test("Test Function validatePedFiles with familyPed meta specified for some members only") {
        when {
            function {
                //The validation should succeed: members without familyPed are ignored,
                //and the remaining members all share the same value.
                """
                input[0] = "family2"
                input[1] = [
                    [[sample:"NA07019", familyId:"family2", sequencingType:"WES", familyPed: "data-test/ped/family2.ped"], "data-test/gvcf/NA07019.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07022", familyId:"family2", sequencingType:"WES", familyPed: "data-test/ped/family2.ped"], "data-test/gvcf/NA07022.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07056", familyId:"family2", sequencingType:"WES"], "data-test/gvcf/NA07056.chr22_50000000-51000000.g.vcf.gz"]
                ]
                """
            }
            then {
                assertAll(
                    { assert function.success }
                )
            }
        }
    }

    test("Test Function validatePedFiles with familyPed meta specified but different") {
        when {
            function {
                //The validation should fail as we expect familyPed to be the same for all family members
                """
                input[0] = "family2"
                input[1] = [
                    [[sample:"NA07019", familyId:"family2", sequencingType:"WES", familyPed: "data-test/ped/family2.ped"], "data-test/gvcf/NA07019.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07022", familyId:"family2", sequencingType:"WES", familyPed: "data-test/ped/family2.ped"], "data-test/gvcf/NA07022.chr22_50000000-51000000.g.vcf.gz"],
                    [[sample:"NA07056", familyId:"family2", sequencingType:"WES", familyPed: "data-test/ped/family1.ped"], "data-test/gvcf/NA07056.chr22_50000000-51000000.g.vcf.gz"]
                ]
                """
            }
            then {
                assertAll(
                    { assert function.failed }
                )
            }
        }
    }
}
